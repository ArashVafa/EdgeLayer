# Copy to .env and fill in your values

# Anthropic — for narrative generation
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# football-data.org — free at football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-key-here

# The Odds API — free tier at the-odds-api.com
ODDS_API_KEY=your-odds-api-key-here

# Database (SQLite local / Postgres on prod)
DATABASE_URL=sqlite:///edgelayer.db

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173
